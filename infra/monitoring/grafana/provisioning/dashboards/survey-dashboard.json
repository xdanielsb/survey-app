{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "gnetId": null,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "type": "timeseries",
      "title": "HTTP Request Latency (avg in ms)",
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table" }
      },
      "targets": [
        {
          "expr": " (sum by(instance)( rate(http_server_requests_seconds_sum[5m]) ) / sum by(instance)( rate(http_server_requests_seconds_count[5m]) )) * 1000 ",
          "legendFormat": "avg latency (ms) ({{instance}})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "type": "timeseries",
      "title": "Error Rate (5xx or 4xx errors/sec)",
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table" }
      },
      "targets": [
        {
          "expr": "sum by (instance)( rate(http_server_requests_seconds_count{status!~\"2..|3..\"}[5m]) )",
          "legendFormat": "5xx/sec ({{instance}})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "type": "timeseries",
      "title": "Traffic (Requests/sec)",
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table" }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "Requests/sec",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "type": "timeseries",
      "title": "Saturation (CPU & Memory)",
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "percent" },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table" }
      },
      "targets": [
        {
          "expr": "100 - (avg by (instance)( irate(node_cpu_seconds_total{mode=\"idle\"}[5m]) ) * 100)",
          "legendFormat": "CPU Usage (%) ({{instance}})",
          "refId": "A"
        },
        {
          "expr": "node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes * 100",
          "legendFormat": "Memory Available (%)",
          "refId": "B"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["survey-app"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "title": "Survey-App Overview",
  "version": 4
}
