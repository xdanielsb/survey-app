# PostgreSQL configuration
PGHOST=localhost
PGPORT=5432
PGUSER=admin
PGPASSWORD=secret
PGDATABASE=survey

# Backup settings
BACKUP_DIR=./backups
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=

# Cron schedules
BACKUP_CRON=0 0 * * *
CLEANUP_CRON=0 1 * * *

# Retention policy
RETENTION_DAYS=30
S3_BUCKET=bucket-name
