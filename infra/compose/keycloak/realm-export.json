[
  {
    "realm": "survey-production",
    "enabled": true,
    "registrationAllowed": true,
    "defaultRoles": ["customer"],
    "roles": {
      "realm": [
        { "name": "admin" },
        { "name": "superadmin" },
        { "name": "manager" },
        { "name": "customer" }
      ]
    },
    "identityProviders": [
      {
        "alias": "google",
        "providerId": "google",
        "enabled": true,
        "updateProfileFirstLoginMode": "on",
        "trustEmail": true,
        "storeToken": true,
        "addReadTokenRoleOnCreate": false,
        "authenticateByDefault": false,
        "linkOnly": false,
        "config": {
          "clientId": "${GOOGLE_CLIENT_ID_PROD}",
          "clientSecret": "${GOOGLE_CLIENT_SECRET_PROD}",
          "defaultScope": "email profile"
        }
      }
    ],
    "clients": [
      {
        "clientId": "backoffice",
        "publicClient": true,
        "redirectUris": ["https://${DOMAIN_URL}/backoffice/*"],
        "webOrigins": ["*"]
      },
      {
        "clientId": "backend",
        "publicClient": false,
        "secret": "${KC_CLIENT_PROD_BACKEND_SECRET}",
        "serviceAccountsEnabled": true,
        "standardFlowEnabled": false,
        "directAccessGrantsEnabled": true,
        "redirectUris": [],
        "webOrigins": []
      },
      {
        "clientId": "frontend",
        "publicClient": true,
        "redirectUris": ["https://${DOMAIN_URL}/*"],
        "webOrigins": ["*"],
        "standardFlowEnabled": true
      }
    ]
  },
  {
    "realm": "survey-staging",
    "enabled": true,
    "registrationAllowed": true,
    "defaultRoles": ["customer"],
    "roles": {
      "realm": [
        { "name": "admin" },
        { "name": "superadmin" },
        { "name": "manager" },
        { "name": "customer" }
      ]
    },
    "identityProviders": [
      {
        "alias": "google",
        "providerId": "google",
        "enabled": true,
        "updateProfileFirstLoginMode": "on",
        "trustEmail": true,
        "storeToken": true,
        "addReadTokenRoleOnCreate": false,
        "authenticateByDefault": false,
        "linkOnly": false,
        "config": {
          "clientId": "${GOOGLE_CLIENT_ID_STAGING}",
          "clientSecret": "${GOOGLE_CLIENT_SECRET_STAGING}",
          "defaultScope": "email profile"
        }
      }
    ],
    "clients": [
      {
        "clientId": "backoffice",
        "publicClient": true,
        "redirectUris": ["https://staging.${DOMAIN_URL}/backoffice/*"],
        "webOrigins": ["*"]
      },
      {
        "clientId": "backend",
        "publicClient": false,
        "secret": "${KC_CLIENT_STAGING_BACKEND_SECRET}",
        "serviceAccountsEnabled": true,
        "standardFlowEnabled": false,
        "directAccessGrantsEnabled": true,
        "redirectUris": [],
        "webOrigins": []
      },
      {
        "clientId": "frontend",
        "publicClient": true,
        "redirectUris": ["https://staging.${DOMAIN_URL}/*"],
        "webOrigins": ["*"],
        "standardFlowEnabled": true
      }
    ]
  },
  {
    "realm": "survey-development",
    "enabled": true,
    "registrationAllowed": true,
    "defaultRoles": ["customer"],
    "roles": {
      "realm": [
        { "name": "admin" },
        { "name": "superadmin" },
        { "name": "manager" },
        { "name": "customer" }
      ]
    },
    "identityProviders": [
      {
        "alias": "google",
        "providerId": "google",
        "enabled": true,
        "updateProfileFirstLoginMode": "on",
        "trustEmail": true,
        "storeToken": true,
        "addReadTokenRoleOnCreate": false,
        "authenticateByDefault": false,
        "linkOnly": false,
        "config": {
          "clientId": "${GOOGLE_CLIENT_ID_STAGING}",
          "clientSecret": "${GOOGLE_CLIENT_SECRET_STAGING}",
          "defaultScope": "email profile"
        }
      }
    ],
    "clients": [
      {
        "clientId": "backoffice",
        "publicClient": true,
        "redirectUris": ["http://localhost:4200/*"],
        "webOrigins": ["*"]
      },
      {
        "clientId": "backend",
        "publicClient": false,
        "secret": "secret",
        "serviceAccountsEnabled": true,
        "standardFlowEnabled": false,
        "directAccessGrantsEnabled": true,
        "redirectUris": [],
        "webOrigins": []
      },
      {
        "clientId": "frontend",
        "publicClient": true,
        "redirectUris": ["http://localhost:5173/*"],
        "webOrigins": ["*"],
        "standardFlowEnabled": true
      }
    ]
  }
