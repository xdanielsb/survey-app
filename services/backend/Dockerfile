FROM maven:3.9-eclipse-temurin-11 AS builder
WORKDIR /app
COPY . .
RUN ./mvnw clean package -DskipTests

FROM eclipse-temurin:17-jdk
WORKDIR /app
COPY --from=builder /app/target/*.jar app.jar

ARG LOGSTASH_HOST
ENV LOGSTASH_HOST=$LOGSTASH_HOST

ARG SENTRY_AUTH_TOKEN
ENV SENTRY_AUTH_TOKEN=$SENTRY_AUTH_TOKEN

ARG SENTRY_AUTH_DSN
ENV SENTRY_AUTH_DSN=$SENTRY_AUTH_DSN


ARG STRIPE_SECRET_KEY
ENV STRIPE_SECRET_KEY=$STRIPE_SECRET_KEY

ARG STRIPE_WEBHOOK_SECRET
ENV STRIPE_WEBHOOK_SECRET=$STRIPE_WEBHOOK_SECRET

ARG STRIPE_PRICE_ID
ENV STRIPE_PRICE_ID=$STRIPE_PRICE_ID

ARG STRIPE_FRONTEND_URL
ENV STRIPE_FRONTEND_URL=$STRIPE_FRONTEND_URL

ARG ANALYTICS_URL 
ENV ANALYTICS_URL=$ANALYTICS_URL

ARG SENDGRID_API_KEY
ENV SENDGRID_API_KEY=$SENDGRID_API_KEY

ARG SENDGRID_FROM_EMAIL
ENV SENDGRID_FROM_EMAIL=$SENDGRID_FROM_EMAIL

ARG KEYCLOAK_URL
ENV KEYCLOAK_URL=$KEYCLOAK_URL

ARG KEYCLOAK_ADMIN
ENV KEYCLOAK_ADMIN=$KEYCLOAK_ADMIN

ARG KEYCLOAK_ADMIN_PASSWORD
ENV KEYCLOAK_ADMIN_PASSWORD=$KEYCLOAK_ADMIN_PASSWORD

ARG KEYCLOAK_REALM
ENV KEYCLOAK_REALM=$KEYCLOAK_REALM

ARG KEYCLOAK_CLIENT_SECRET
ENV KEYCLOAK_CLIENT_SECRET=$KEYCLOAK_CLIENT_SECRET

ARG INVOICE_STORAGE_PATH
ENV INVOICE_STORAGE_PATH=$INVOICE_STORAGE_PATH

ARG ENVIRONMENT
ENV ENVIRONMENTS=$ENVIRONMENT

EXPOSE 8080
ENTRYPOINT ["java", "-jar", "app.jar"]
